// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

model Credentials {
  user_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gmail          String   @unique
  password       String
  created_at     DateTime @default(now())
  is_logged_in   Boolean  @default(false)
  last_signin_at DateTime @updatedAt
  role           String   @default("User")
  is_remembered  Boolean  @default(false)

  user_profile UserProfile?
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model UserProfile {
  user_profile_id  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  credentials_id   String      @unique @db.Uuid
  credentials      Credentials @relation(fields: [credentials_id], references: [user_id], onDelete: Cascade)

  full_name        String
  username         String      @unique
  avatar_pic       String?
  background_cover String?
  specialization   String?
  gender           Gender      @default(PREFER_NOT_TO_SAY)
  is_open_for_hire Boolean     @default(false)
  birthdate        DateTime?
  contact          String?
  about_me         String?     @db.Text
  social_links     Json?
  display_location String?

  updated_at       DateTime    @updatedAt
  posts            Post[]
  artworks         Artwork[]
}

enum Visibility {
  public
  followers
  private
}

model Post {
  post_id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_profile_id String      @db.Uuid
  content         String      @db.VarChar(500)
  media           String[]    // Array of image URLs
  visibility      Visibility  @default(public)
  date_posted     DateTime    @default(now())
  last_updated    DateTime    @updatedAt

  author          UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  // comments        Comment[]   @relation("PostComments")
}

model Artwork {
  artwork_id      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Foreign key to UserProfile
  user_profile_id String      @db.Uuid
  user_profile    UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  art_file        String
  artwork_title   String
  description     String?     @db.Text
  artwork_type    String      // Can also be converted into an Enum (e.g., "Digital", "Traditional")
  tags            String[]
  status          String      // Can be updated to an Enum (e.g., For Sale, Draft)
  price           Float       // Alternatively, you can use Decimal for higher precision currency
  stocks          Int         @default(0)
  sold            Int         @default(0)
  gallery_id      String?     @db.Uuid
  likes_count     Int         @default(0)

  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  // comments        Comment[]   @relation("ArtworkComments")
}

