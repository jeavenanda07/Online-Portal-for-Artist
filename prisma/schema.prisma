// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Credentials {
  user_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gmail          String   @unique
  password       String
  created_at     DateTime @default(now())
  is_logged_in   Boolean  @default(false)
  last_signin_at DateTime @updatedAt
  role           String   @default("User")
  is_remembered  Boolean  @default(false)

  user_profile UserProfile?
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model UserProfile {
  user_profile_id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  credentials_id String      @unique @db.Uuid
  credentials    Credentials @relation(fields: [credentials_id], references: [user_id], onDelete: Cascade)

  full_name        String
  username         String    @unique
  avatar_pic       String?
  background_cover String?
  specialization   String?
  gender           Gender    @default(PREFER_NOT_TO_SAY)
  is_open_for_hire Boolean   @default(false)
  birthdate        DateTime?
  contact          String?
  about_me         String?   @db.Text
  social_links     Json?
  display_location String?

  skills          String[]
  updated_at      DateTime      @updatedAt
  posts           Post[]
  artworks        Artwork[]
  post_likes      PostLike[] // 👈 add this
  post_comments   PostComment[]
  galleries       Gallery[]
  followers       Follow[]      @relation("UserFollowing") // people who follow ME
  following       Follow[]      @relation("UserFollowers") // people I follow
  artist_requests ArtRequest[]  @relation("ArtistRequests") // commissions I received
  client_requests ArtRequest[]  @relation("ClientRequests") // commissions I sent
  artwork_comments     ArtworkComment[]
  artwork_likes        ArtworkLike[]
  notifications_received Notification[]   @relation("NotificationRecipient")
  notifications_sent     Notification[]   @relation("NotificationSender")
  purchases_as_buyer   PurchasedArt[]     @relation("BuyerPurchases")
  purchases_as_seller  PurchasedArt[]     @relation("SellerPurchases")
  artwork_violations_reported   ArtworkViolationLog[] @relation("ArtworkReportedUser")
  artwork_violations_filed      ArtworkViolationLog[] @relation("ArtworkReporter")
  artist_violations_reported    ArtistViolationLog[]  @relation("ArtistReportedUser")
  artist_violations_filed       ArtistViolationLog[]  @relation("ArtistReporter")
}

enum Visibility {
  public
  followers
  private
}

model Post {
  post_id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_profile_id String     @db.Uuid
  content         String     @db.VarChar(500)
  media           String[]
  visibility      Visibility @default(public)
  date_posted     DateTime   @default(now())
  last_updated    DateTime   @updatedAt

  author UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  likes    PostLike[]
  comments PostComment[]
}

model Artwork {
  artwork_id      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_profile_id String      @db.Uuid
  user_profile    UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  art_file      String
  artwork_title String
  description   String?  @db.Text
  artwork_type  String // Can also be converted into an Enum (e.g., "Digital", "Traditional")
  tags          String[]
  status        String // Can be updated to an Enum (e.g., For Sale, Draft)
  price         Float // Alternatively, you can use Decimal for higher precision currency
  stocks        Int      @default(0)
  sold          Int      @default(0)
  gallery_id    String?  @db.Uuid
  likes_count   Int      @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  gallery_artworks GalleryArtwork[]
    artwork_comments     ArtworkComment[]
  artwork_likes        ArtworkLike[]
  purchases            PurchasedArt[]
  violation_logs       ArtworkViolationLog[]  
}

model PostLike {
  like_id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id         String   @db.Uuid
  user_profile_id String   @db.Uuid
  created_at      DateTime @default(now())

  post         Post        @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  user_profile UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  @@unique([post_id, user_profile_id]) // prevent duplicate likes
}

model PostComment {
  comment_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id         String   @db.Uuid
  user_profile_id String   @db.Uuid
  content         String   @db.VarChar(500)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  post         Post        @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  user_profile UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)
}

model Gallery {
  id              String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_profile_id String @db.Uuid

  user_profile UserProfile       @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)
  title        String
  slug         String            @unique
  description  String?
  cover_image  String?
  visibility   galleryVisibility @default(public)

  artworks GalleryArtwork[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model GalleryArtwork {
  gallery_id String @db.Uuid

  artwork_id String   @db.Uuid
  gallery    Gallery  @relation(fields: [gallery_id], references: [id], onDelete: Cascade)
  artwork    Artwork  @relation(fields: [artwork_id], references: [artwork_id], onDelete: Cascade)
  added_at   DateTime @default(now())

  @@id([gallery_id, artwork_id]) // Composite Primary Key
}

enum galleryVisibility {
  public
  private
}

model Follow {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  follower_id  String   @db.Uuid
  following_id String   @db.Uuid
  created_at   DateTime @default(now())

  follower  UserProfile @relation("UserFollowers", fields: [follower_id], references: [user_profile_id], onDelete: Cascade)
  following UserProfile @relation("UserFollowing", fields: [following_id], references: [user_profile_id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@map("follows")
}

enum ArtRequestStatus {
  Pending
  Accepted
  Rejected
  InProgress
  Completed
  Cancelled
}

enum ArtType {
  DigitalArt
  Traditional
  ThreeD
  PixelArt
  Illustration
  Other
}

model ArtRequest {
  art_request_id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artist_id String      @db.Uuid
  artist    UserProfile @relation("ArtistRequests", fields: [artist_id], references: [user_profile_id], onDelete: Cascade)
  client_id String      @db.Uuid
  client    UserProfile @relation("ClientRequests", fields: [client_id], references: [user_profile_id], onDelete: Cascade)

  title            String
  description      String           @db.Text
  art_type         ArtType          @default(DigitalArt)
  budget           Float
  deadline         DateTime?
  tags             String[]
  reference_images String[] // store uploaded image URLs
  status           ArtRequestStatus @default(Pending)

  // Shipping info (for physical artworks)
  shipping_name    String?
  shipping_address String?
  shipping_contact String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("art_requests")
}

// ── Artwork Comment ───────────────────────────────────────────
model ArtworkComment {
  comment_id      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artwork_id      String      @db.Uuid
  user_profile_id String      @db.Uuid
  content         String      @db.VarChar(500)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  artwork      Artwork     @relation(fields: [artwork_id], references: [artwork_id], onDelete: Cascade)
  user_profile UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  @@map("artwork_comments")
}

// ── Artwork Like ──────────────────────────────────────────────
model ArtworkLike {
  like_id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  artwork_id      String   @db.Uuid
  user_profile_id String   @db.Uuid
  created_at      DateTime @default(now())

  artwork      Artwork     @relation(fields: [artwork_id], references: [artwork_id], onDelete: Cascade)
  user_profile UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  @@unique([artwork_id, user_profile_id]) // prevent duplicate likes
  @@map("artwork_likes")
}

// ── Notification ──────────────────────────────────────────────
enum NotificationType {
  LIKE_POST
  LIKE_ARTWORK
  COMMENT_POST
  COMMENT_ARTWORK
  FOLLOW
  COMMISSION_ACCEPTED
  COMMISSION_REJECTED
  COMMISSION_COMPLETED
}

model Notification {
  notification_id String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Who receives the notification
  recipient_id    String           @db.Uuid
  recipient       UserProfile      @relation("NotificationRecipient", fields: [recipient_id], references: [user_profile_id], onDelete: Cascade)

  // Who triggered the notification
  sender_id       String           @db.Uuid
  sender          UserProfile      @relation("NotificationSender", fields: [sender_id], references: [user_profile_id], onDelete: Cascade)

  type            NotificationType
  is_read         Boolean          @default(false)

  // Optional references — only one will be set depending on type
  post_id         String?          @db.Uuid
  artwork_id      String?          @db.Uuid
  art_request_id  String?          @db.Uuid

  message         String?          // e.g. "liked your artwork"
  created_at      DateTime         @default(now())

  @@map("notifications")
}

// ── Purchased Art ─────────────────────────────────────────────
enum PurchaseStatus {
  Pending
  Completed
  Cancelled
  Refunded
}

model PurchasedArt {
  purchase_id     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  buyer_id        String         @db.Uuid
  buyer           UserProfile    @relation("BuyerPurchases", fields: [buyer_id], references: [user_profile_id], onDelete: Cascade)
  seller_id       String         @db.Uuid
  seller          UserProfile    @relation("SellerPurchases", fields: [seller_id], references: [user_profile_id], onDelete: Cascade)
  artwork_id      String         @db.Uuid
  artwork         Artwork        @relation(fields: [artwork_id], references: [artwork_id], onDelete: Cascade)

  price_at_purchase Float        // snapshot of price at time of purchase
  quantity        Int            @default(1)
  total_amount    Float          // price_at_purchase * quantity

  status          PurchaseStatus @default(Pending)
  shipping_name    String?
  shipping_address String?
  shipping_contact String?

  purchased_at    DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  @@map("purchased_arts")
}

// ── Artwork Violation Log ─────────────────────────────────────
enum ArtworkViolationReason {
  Copyright_Issue
  NSFW
  Abuse
  Scam
  Spam
  Plagiarism
  Other
}

enum ArtworkViolationStatus {
  Pending
  Reviewed
  Warning_Issued
  Suspended
  Dismissed
}

model ArtworkViolationLog {
  violation_log_id  String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  artwork_id        String                 @db.Uuid
  artwork           Artwork                @relation(fields: [artwork_id], references: [artwork_id], onDelete: Cascade)

  // Owner of the artwork
  reported_user_id  String                 @db.Uuid
  reported_user     UserProfile            @relation("ArtworkReportedUser", fields: [reported_user_id], references: [user_profile_id], onDelete: Cascade)

  // User who filed the report
  reported_by_id    String                 @db.Uuid
  reported_by       UserProfile            @relation("ArtworkReporter", fields: [reported_by_id], references: [user_profile_id], onDelete: Cascade)

  reason            ArtworkViolationReason
  description       String?                @db.Text
  status            ArtworkViolationStatus @default(Pending)

  date_reported     DateTime               @default(now())
  reviewed_at       DateTime?

  @@map("artwork_violation_logs")
}

// ── Artist Violation Log ──────────────────────────────────────
enum ArtistViolationReason {
  Harassment
  Scam
  Fake_Identity
  Spam
  Hate_Speech
  Fraud
  Other
}

enum ArtistViolationStatus {
  Pending
  Reviewed
  Warned
  Suspended
  Cleared
}

model ArtistViolationLog {
  violation_log_id  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // User being reported
  reported_user_id  String                @db.Uuid
  reported_user     UserProfile           @relation("ArtistReportedUser", fields: [reported_user_id], references: [user_profile_id], onDelete: Cascade)

  // User who filed the report
  reported_by_id    String                @db.Uuid
  reported_by       UserProfile           @relation("ArtistReporter", fields: [reported_by_id], references: [user_profile_id], onDelete: Cascade)

  reason            ArtistViolationReason
  description       String?               @db.Text
  status            ArtistViolationStatus @default(Pending)

  date_reported     DateTime              @default(now())
  reviewed_at       DateTime?

  @@map("artist_violation_logs")
}