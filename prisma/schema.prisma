// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Credentials {
  user_id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gmail          String   @unique
  password       String
  created_at     DateTime @default(now())
  is_logged_in   Boolean  @default(false)
  last_signin_at DateTime @updatedAt
  role           String   @default("User")
  is_remembered  Boolean  @default(false)

  user_profile UserProfile?
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

model UserProfile {
  user_profile_id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  credentials_id String      @unique @db.Uuid
  credentials    Credentials @relation(fields: [credentials_id], references: [user_id], onDelete: Cascade)

  full_name        String
  username         String    @unique
  avatar_pic       String?
  background_cover String?
  specialization   String?
  gender           Gender    @default(PREFER_NOT_TO_SAY)
  is_open_for_hire Boolean   @default(false)
  birthdate        DateTime?
  contact          String?
  about_me         String?   @db.Text
  social_links     Json?
  display_location String?

  skills        String[]
  updated_at    DateTime      @updatedAt
  posts         Post[]
  artworks      Artwork[]
  post_likes    PostLike[] // 👈 add this
  post_comments PostComment[]
  galleries     Gallery[]
  followers     Follow[]      @relation("UserFollowing") // people who follow ME
  following     Follow[]      @relation("UserFollowers") // people I follow
}

enum Visibility {
  public
  followers
  private
}

model Post {
  post_id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_profile_id String     @db.Uuid
  content         String     @db.VarChar(500)
  media           String[]
  visibility      Visibility @default(public)
  date_posted     DateTime   @default(now())
  last_updated    DateTime   @updatedAt

  author UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  likes    PostLike[]
  comments PostComment[]
}

model Artwork {
  artwork_id      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_profile_id String      @db.Uuid
  user_profile    UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  art_file      String
  artwork_title String
  description   String?  @db.Text
  artwork_type  String // Can also be converted into an Enum (e.g., "Digital", "Traditional")
  tags          String[]
  status        String // Can be updated to an Enum (e.g., For Sale, Draft)
  price         Float // Alternatively, you can use Decimal for higher precision currency
  stocks        Int      @default(0)
  sold          Int      @default(0)
  gallery_id    String?  @db.Uuid
  likes_count   Int      @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  gallery_artworks GalleryArtwork[]
  // comments        Comment[]   @relation("ArtworkComments")
}

model PostLike {
  like_id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id         String   @db.Uuid
  user_profile_id String   @db.Uuid
  created_at      DateTime @default(now())

  post         Post        @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  user_profile UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)

  @@unique([post_id, user_profile_id]) // prevent duplicate likes
}

model PostComment {
  comment_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id         String   @db.Uuid
  user_profile_id String   @db.Uuid
  content         String   @db.VarChar(500)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  post         Post        @relation(fields: [post_id], references: [post_id], onDelete: Cascade)
  user_profile UserProfile @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)
}

model Gallery {
  id              String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_profile_id String @db.Uuid

  user_profile UserProfile       @relation(fields: [user_profile_id], references: [user_profile_id], onDelete: Cascade)
  title        String
  slug         String            @unique
  description  String?
  cover_image  String?
  visibility   galleryVisibility @default(public)

  artworks GalleryArtwork[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model GalleryArtwork {
  gallery_id String @db.Uuid

  artwork_id String   @db.Uuid
  gallery    Gallery  @relation(fields: [gallery_id], references: [id], onDelete: Cascade)
  artwork    Artwork  @relation(fields: [artwork_id], references: [artwork_id], onDelete: Cascade)
  added_at   DateTime @default(now())

  @@id([gallery_id, artwork_id]) // Composite Primary Key
}

enum galleryVisibility {
  public
  private
}

model Follow {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  follower_id  String   @db.Uuid
  following_id String   @db.Uuid
  created_at   DateTime @default(now())

  follower  UserProfile @relation("UserFollowers", fields: [follower_id], references: [user_profile_id], onDelete: Cascade)
  following UserProfile @relation("UserFollowing", fields: [following_id], references: [user_profile_id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@map("follows")
}
